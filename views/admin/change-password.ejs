<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — The Candy Connection</title>
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@600;700;800&display=swap"
    rel="stylesheet"
  />
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="admin-auth-body">
  <div class="auth-card">
    <div class="auth-logo" aria-hidden="true">🔒</div>
    <h1>Change Password</h1>
    <% if (forced) { %>
      <p class="auth-sub">For security, please set a new password before continuing.</p>
    <% } else { %>
      <p class="auth-sub">Update your admin password.</p>
    <% } %>

    <%- include('../partials/flash') %>

    <form method="post" action="/admin/change-password" autocomplete="off">
      <% if (!forced) { %>
        <div class="form-group">
          <label for="current_password">Current Password</label>
          <input type="password" id="current_password" name="current_password" required />
        </div>
      <% } %>
      <div class="form-group">
        <label for="new_password">New Password</label>
        <input type="password" id="new_password" name="new_password" required minlength="8" />
        <small class="field-hint">At least 8 characters.</small>
      </div>
      <div class="form-group">
        <label for="confirm_password">Confirm New Password</label>
        <input type="password" id="confirm_password" name="confirm_password" required minlength="8" />
      </div>
      <button type="submit" class="btn btn-primary btn-block btn-lg">Update Password</button>
    </form>

    <% if (!forced) { %>
      <a class="auth-back" href="/admin/dashboard">← Back to dashboard</a>
    <% } else { %>
      <form method="post" action="/admin/logout"><button class="auth-back-btn" type="submit">Log out</button></form>
    <% } %>
  </div>
</body>
</html>
