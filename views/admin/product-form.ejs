<%- include('partials/head') %>

<%
  var isEdit = !!product;
  var action = isEdit ? ('/admin/catalog/' + product.id + '/edit') : '/admin/catalog/new';
%>

<div class="panel">
  <div class="panel-head">
    <h2 class="panel-title"><%= isEdit ? 'Edit Product' : 'Add New Product' %></h2>
    <a href="/admin/catalog" class="btn btn-outline btn-sm">← Back to Catalog</a>
  </div>

  <form method="post" action="<%= action %>" enctype="multipart/form-data" class="admin-form">
    <div class="form-group">
      <label for="name">Product Name *</label>
      <input type="text" id="name" name="name" required value="<%= isEdit ? product.name : '' %>" />
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="category">Category</label>
        <select id="category" name="category">
          <option value="">— None —</option>
          <% categories.forEach(function (c) { %>
            <option value="<%= c.name %>" <%= isEdit && product.category === c.name ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label for="price">Price</label>
        <input type="text" id="price" name="price" value="<%= isEdit ? (product.price || '') : '' %>" placeholder="e.g. 12.50 or Price on Request" />
        <small class="field-hint">Enter a number, or leave blank for "Price on Request".</small>
      </div>
    </div>

    <div class="form-group">
      <label for="packaging">Packaging</label>
      <input type="text" id="packaging" name="packaging" value="<%= isEdit ? (product.packaging || '') : '' %>" placeholder="e.g. 500g Pack, Box of 24" />
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea id="description" name="description" rows="4"><%= isEdit ? (product.description || '') : '' %></textarea>
    </div>

    <div class="form-group">
      <label for="image">Product Image</label>
      <input type="file" id="image" name="image" accept="image/jpeg,image/png,image/webp" data-preview="imgPreview" />
      <small class="field-hint">JPG, PNG or WEBP · max 5MB.</small>
      <div class="image-preview">
        <img id="imgPreview" src="<%= isEdit ? h.imageUrl(product.image_path) : h.PLACEHOLDER_IMAGE %>" alt="Preview" />
      </div>
      <% if (isEdit && product.image_path) { %>
        <label class="checkbox-row">
          <input type="checkbox" name="remove_image" value="1" /> Remove current image
        </label>
      <% } %>
    </div>

    <div class="form-group">
      <label class="checkbox-row">
        <input type="checkbox" name="is_visible" value="1" <%= (!isEdit || product.is_visible) ? 'checked' : '' %> />
        Visible on public catalog
      </label>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary btn-lg"><%= isEdit ? 'Save Changes' : 'Add Product' %></button>
      <a href="/admin/catalog" class="btn btn-outline btn-lg">Cancel</a>
    </div>
  </form>
</div>

<%- include('partials/foot') %>
