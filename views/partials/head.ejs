<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <meta name="description" content="<%= locals.metaDescription || '' %>" />
  <meta property="og:title" content="<%= title %>" />
  <meta property="og:description" content="<%= locals.metaDescription || '' %>" />
  <meta property="og:type" content="website" />
  <meta name="theme-color" content="#FFB6C1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <%
    var fontHref = 'https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Nunito:wght@600;700;800&family=Poppins:wght@500;600;700;800&display=swap';
  %>
  <!-- Load fonts without blocking render; system-ui fallback shows instantly, then swaps. -->
  <link rel="stylesheet" href="<%= fontHref %>" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="<%= fontHref %>" /></noscript>
  <link rel="stylesheet" href="/css/main.css" />
  <% (locals.extraCss || []).forEach(function (href) { %>
    <link rel="stylesheet" href="<%= href %>" />
  <% }) %>
</head>
<body>
