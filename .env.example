# Copy this file to ".env" and fill in the values. Local dev + scripts read these.

# Port for local dev (Vercel assigns its own in production).
PORT=3000

# Postgres connection string.
# In production, Vercel Postgres / Neon inject POSTGRES_URL automatically.
# For local dev, point this at your Postgres (cloud or local), e.g.:
#   POSTGRES_URL=postgres://user:pass@localhost:5432/candy
POSTGRES_URL=

# Vercel Blob token for image uploads (from your Vercel Blob store).
# If unset, uploads fall back to local disk (public/uploads/) — dev only.
BLOB_READ_WRITE_TOKEN=

# Secret used to sign the admin session cookie. Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-secret

# Set to "production" behind HTTPS to enable secure cookies.
NODE_ENV=development
